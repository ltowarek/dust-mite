          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100,
              "color": {
                "mode": "palette-classic"
              },
              "custom": {
                "lineWidth": 0,
                "fillOpacity": 80,
                "stacking": {
                  "group": "A",
                  "mode": "normal"
                },
                "scaleDistribution": {
                  "type": "linear"
